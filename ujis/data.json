---
layout: null
permalink: /ujis/data.json
---

[
  {
    "id": "0",
    "data": {
      "fn": "OSU",
      "ln": "Lambdas",
      "desc": "A family of OSU Lambdas",
      "image": "{{ '/images/background.webp' | relative_url }}",
      "label": "OSU Lambdas"
    },
    "rels": {
      "spouses": [],
      "children": [
        {%- assign root_members = site.members | where: "father", 0 | sort: "number" -%}
        {%- for member in root_members -%}
          "{{ member.number }}"{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    },
    "main": true
  }
  {%- assign sorted_members = site.members | sort: "number" -%}
  {%- for member in sorted_members -%}
  ,{
    "id": "{{ member.number }}",
    "data": {
      "fn": {{ member.fn | default: "" | jsonify }},
      "ln": {{ member.ln | default: "" | jsonify }},
      "label": {{ member.description | default: member.fn | jsonify }},
      "desc": {{ member.fn | append: " " | append: member.ln | strip | jsonify }},
      "image": {{ member.image | relative_url | jsonify }}
    },
    "rels": {
      "father": "{% if member.father and member.father != '' %}{{ member.father }}{% else %}0{% endif %}",
      "spouses": [],
      "children": [
        {%- assign child_members = site.members | where: "father", member.number | sort: "number" -%}
        {%- for child in child_members -%}
          "{{ child.number }}"{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  }
  {%- endfor -%}
]